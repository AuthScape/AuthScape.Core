{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },

  // OpenIddict example host: this host always validates tokens issued by OpenIddict.IDP
  // (https://localhost:44303). Move the introspection secret to user-secrets / env
  // (Authentication__OpenIddict__IntrospectionClientSecret) for non-dev environments.
  "Authentication": {
    "Provider": "OpenIddict",
    "AutoProvisionUsers": true,

    "OpenIddict": {
      "AccessTokenLifetime": "01:00:00",
      "AllowRefreshTokens": true,
      "AllowClientCredentials": true,
      "UseIntrospection": true,
      "Issuer": "https://localhost:44303/",
      "Audience": "resource_server_1",
      "IntrospectionClientId": "resource_server_1",
      "IntrospectionClientSecret": "846B62D0-DEF9-4215-A99D-86E6B8DAB342"
    }
  }
}
