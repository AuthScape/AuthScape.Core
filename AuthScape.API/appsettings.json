{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },

  // Single AuthScape API host. The token issuer is chosen by "Authentication:Provider" — set it to
  // "OpenIddict" or "Keycloak". This is the ONLY place to flip providers (no code change/rebuild):
  //   - OpenIddict: run the OpenIddict.IDP project (issuer at https://localhost:44303).
  //   - Keycloak:   run Keycloak via ../docker-compose.yml (realm "authscape" on :8080).
  // Both provider sections are present below; only the one named by "Provider" is bound at startup.
  // Move secrets to user-secrets / env (e.g. Authentication__OpenIddict__IntrospectionClientSecret)
  // for non-dev environments.
  "Authentication": {
    "Provider": "OpenIddict",
    "AutoProvisionUsers": true,

    "OpenIddict": {
      "AccessTokenLifetime": "01:00:00",
      "AllowRefreshTokens": true,
      "AllowClientCredentials": true,
      "UseIntrospection": true,
      "Issuer": "https://localhost:44303/",
      "Audience": "resource_server_1",
      "IntrospectionClientId": "resource_server_1",
      "IntrospectionClientSecret": "846B62D0-DEF9-4215-A99D-86E6B8DAB342"
    },

    // RequireHttpsMetadata is false because dev Keycloak serves plain HTTP on :8080.
    // Flip UseIntrospection to true to exercise the introspection path instead of local JWT.
    "Keycloak": {
      "Authority": "http://localhost:8080/realms/authscape",
      "ClientId": "authscape-api",
      "RequireHttpsMetadata": false,
      "UseIntrospection": false,
      "IntrospectionClientId": "authscape-api",
      "IntrospectionClientSecret": "authscape-api-dev-secret"
    }
  }
}
