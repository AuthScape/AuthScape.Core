{
  "AppSettings": {
    "Name": "Authscape",
    "Stage": 1,
    "IDPUrl": "https://localhost:44303",
    "WebsiteRedirectUrl": "http://localhost:3000",
    "InviteSignupRedirectUrl": "http://localhost:3000",
    "LoginRedirectUrl": "http://localhost:3000",
    "DataProtectionTokenProviderOptions_TokenLifespanByDays": 1,
    "EnableCompanyMode": true, // Will display Company within signup and also store company against payment processes vs user level
    "Storage": {
      "AzureConnectionString": "",
      "BaseUri": "https://storage.website.com",
      "UserProfileContainer": "userphoto"
    },
    "Stripe": {
      "PublishableKey": "key",
      "SecretKey": "secret",
      "SigningSecret": ""
    },
    "Ticketing": {
      "TemplateId": "sendgridTemplateId",
      "Domain": "domain",
      "Name": "company Name",
      "Subject": "New Message"
    },
    "OpenAI": {
      "APIKey": ""
    },
    "DocumentProcessing": {
      "StorageContainer": "containerName",
      "BaseURL": "https://yoursite.blob.core.windows.net",
      "AzureFormRecognizerEndpoint": "https://yoursite.cognitiveservices.azure.com/",
      "AzureFormRecognizerKey": "your key"
    },
    "WhiteLabel": {
      "GoogleFontsAPIKey": "",
      "AppIconContainer": "appicons"
    },
    "FirebaseBrowserPushNotification_APIKey": "",
    "SendGrid": {
      "APIKey": "",
      "FromEmail": "",
      "FromName": "",
      "AchVerificationInitialTemplateId": "",
      "AchVerificationReminderTemplateId": ""
    },
    "SendGridWebhook": {
      "NewEmail": "new@mydomain.com" // This is for new emails coming into the system
    },
    "Authentication": {
      "EnableCompany": true,
      "SearchCompany": true
    },
    "Slack": {
      "UserName": "botName",
      "IconUrl": "IconPath",
      "WebhookUrl": "https://hooks.slack.com/services/[yourcode]"
    },
    "DatabaseContext": "Server=localhost,1433;Database=AuthScape;User Id=sa;Password=Your_password123;TrustServerCertificate=true;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  // Dev-only: when Enabled, every request's response time is broadcast over SignalR to the
  // VS Code "Speed Diagnostics" panel. Only ever active when ASPNETCORE_ENVIRONMENT=Development.
  "SpeedDiagnostics": {
    "Enabled": true
  }
}